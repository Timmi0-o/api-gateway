FROM node:22-slim

WORKDIR /app

# Устанавливаем procps для команды ps (требуется для NestJS hot-reload)
RUN apt-get update && apt-get install -y procps && rm -rf /var/lib/apt/lists/*

# Копируем package.json, package-lock.json и .npmrc для главного приложения
COPY api-gateway/package*.json ./
COPY api-gateway/.npmrc ./

# Копируем package.json для локальных пакетов (вместе с tsconfig для их компиляции)
COPY tourgis-contracts/package.json tourgis-contracts/package-lock.json tourgis-contracts/tsconfig.json tourgis-contracts/tsconfig.build.json /tourgis-contracts/
COPY tourgis-errors/package.json tourgis-errors/package-lock.json tourgis-errors/tsconfig.json /tourgis-errors/
COPY tourgis-common/package.json tourgis-common/package-lock.json tourgis-common/tsconfig.json /tourgis-common/

# Устанавливаем зависимости
RUN npm install

# Устанавливаем зависимости для локальных пакетов
RUN cd /tourgis-contracts && npm ci 2>/dev/null || npm install
RUN cd /tourgis-errors && npm ci 2>/dev/null || npm install
RUN cd /tourgis-common && npm ci 2>/dev/null || npm install

EXPOSE 3000

CMD ["sh", "-c", "npm run start:dev"]