FROM node:22-slim

WORKDIR /app

# Устанавливаем procps для команды ps (требуется для NestJS hot-reload)
RUN apt-get update && apt-get install -y procps && rm -rf /var/lib/apt/lists/*

# Копируем локальные пакеты с их package.json и package-lock.json
COPY tourgis-contracts/package.json tourgis-contracts/package-lock.json /tourgis-contracts/
COPY tourgis-contracts/dist/ /tourgis-contracts/dist/

COPY tourgis-errors/package.json tourgis-errors/package-lock.json /tourgis-errors/
COPY tourgis-errors/dist/ /tourgis-errors/dist/

COPY tourgis-common/package.json tourgis-common/package-lock.json /tourgis-common/
COPY tourgis-common/dist/ /tourgis-common/dist/

# Копируем package.json, package-lock.json и .npmrc
COPY api-gateway/package*.json ./
COPY api-gateway/.npmrc ./

# Устанавливаем зависимости
RUN npm ci

# Устанавливаем зависимости для локальных пакетов
RUN cd /tourgis-contracts && npm ci 2>/dev/null || true
RUN cd /tourgis-errors && npm ci 2>/dev/null || true
RUN cd /tourgis-common && npm ci 2>/dev/null || true

# Копируем остальной код
COPY api-gateway/ .

EXPOSE 3000

CMD ["sh", "-c", "npm run start:dev"]